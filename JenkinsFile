pipeline {
    agent any

    tools {
        maven 'apache-maven-3.9.9'
        jdk 'JDK21'
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build & Test') {
            steps {
                bat 'mvn clean test'
            }
        }

        stage('Archive Extent Report') {
            steps {
                archiveArtifacts artifacts: '**/extentReport*.html', fingerprint: true
            }
        }
    }

    post {
        always {
            junit '**/target/surefire-reports/*.xml'
        }
    }
}