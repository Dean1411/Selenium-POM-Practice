<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Parallel cross-browser" parallel="tests" thread-count="5">

	<listeners>
		<listener class-name="reporting.TestListener"></listener>
	</listeners>
	<test name="Chrome">
	<parameter name="browser" value="chrome-headless"></parameter>
		<classes>
			<class name="tests.ValidLoginTest" />
		</classes>
	</test> 
		<test name="Firefox">
		<parameter name="browser" value="firefox-headless"></parameter>
		<classes>
			<class name="tests.ValidLoginTest" />
		</classes>
	</test> 
		<test name="Edge">
		<parameter name="browser" value="edge-headless"></parameter>
		<classes>
			<class name="tests.ValidLoginTest" />
		</classes>
	</test> 
</suite> <!--
Suite -->
