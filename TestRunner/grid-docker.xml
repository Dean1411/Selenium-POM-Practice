	<test thread-count="5" name="Test-FireFox">
		<parameter name="browser" value="firefox"></parameter>
		<parameter name="OS" value="linux"></parameter>
		<classes>
			<!--			<class name="tests.RegisterUserTest" />-->
			<class name="tests.ValidLoginTest" />
